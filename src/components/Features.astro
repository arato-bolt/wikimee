---
import { getFeatures } from '../lib/content.js';

const features = getFeatures();
---

<section class="py-[6rem] bg-white relative z-20" id="features">
  <div class="max-w-[75rem] mx-auto px-[1rem] md:px-[1.5rem] lg:px-[3rem]">
    
    <div class="text-center max-w-[50rem] mx-auto mb-[4rem] fade-section">
      <p class="text-[0.875rem] font-medium text-[#6D28D9] mb-[0.75rem]">Funcionalidades</p>
      <h2 class="text-[2.25rem] sm:text-[3rem] font-bold text-[#0A0A0A] mb-[1rem] leading-tight">
        Tudo que você precisa para gerenciar sua agência
      </h2>
      <p class="text-[1.125rem] text-[#737373]">
        Do portal do cliente aos relatórios — ferramentas integradas que funcionam juntas.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[1.5rem]">
      {features.map((feature) => (
        <div class="bg-white rounded-[1.5rem] p-[2rem] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col items-start text-left h-full group">
          
          <div class="mb-[1.5rem]">
            <div class="w-[3rem] h-[3rem] bg-gray-50 border border-[#E5E5E5] rounded-[0.75rem] flex items-center justify-center text-[#525252] group-hover:text-[#6D28D9] group-hover:border-[#6D28D9]/30 transition-colors">
              <svg class="w-[1.5rem] h-[1.5rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={feature.iconPath} />
              </svg>
            </div>
          </div>
          <h3 class="text-[1.25rem] font-bold text-[#0A0A0A] mb-[0.75rem]">{feature.title}</h3>
          <p class="text-[1rem] text-[#737373] leading-relaxed mb-auto">{feature.description}</p>
          
        </div>
      ))}
    </div>
    
  </div>
</section>

<style>
  .fade-section {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  .fade-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .feature-image {
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }
  
  .feature-image:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 1.5rem 2rem -0.5rem rgba(0, 0, 0, 0.1);
  }
</style>
