---
import { getFAQ } from '../lib/content.js';

const faqs = getFAQ();
---

<section class="py-[6rem] bg-[#FAFAFA] fade-section">
  <div class="max-w-[48rem] mx-auto px-[1rem] md:px-[1.5rem]">
    
    <div class="text-center mb-[3rem]">
      <p class="text-[0.875rem] font-medium text-[#6D28D9] mb-[0.5rem]">FAQ</p>
      <h2 class="text-[2rem] font-semibold text-[#0A0A0A]">
        Perguntas frequentes
      </h2>
    </div>
    
    <div class="space-y-[0.75rem]">
      {faqs.map((faq) => (
        <details class="group bg-white rounded-[0.5rem] border border-[#E5E5E5] hover:border-[#6D28D9]/30 transition-all">
          <summary class="flex justify-between items-center cursor-pointer px-[1.25rem] py-[1.25rem] list-none">
            <span class="text-[1rem] font-medium text-[#0A0A0A]">{faq.question}</span>
            <svg class="w-[1.25rem] h-[1.25rem] text-[#737373] group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-[1.25rem] pb-[1.25rem]">
            <p class="text-[0.875rem] text-[#737373] leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
    
  </div>
</section>

<style>
  .fade-section {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  .fade-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
